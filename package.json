{
  "name": "neurowasm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs'),p=require('path'),s=p.join('node_modules','onnxruntime-web','dist'),d='public';fs.readdirSync(s).filter(f=>f.startsWith('ort-wasm-simd-threaded')).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)))\"",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "onnxruntime-node": "^1.24.3",
    "onnxruntime-web": "^1.24.3"
  }
}
